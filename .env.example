# Archive Engines — Backend Environment Variables
# Copy this file to .env and fill in your values

# Port the server runs on (Railway sets this automatically)
PORT=3001

# Your frontend URL (set this after deploying to Vercel)
FRONTEND_URL=https://your-app.vercel.app

# Optional: Buyee affiliate API key (get from affiliate.buyee.jp)
BUYEE_AFFILIATE_ID=

# Optional: Zenmarket affiliate key
ZENMARKET_AFFILIATE_ID=
